#!/usr/bin/env bash
set -e

if command -v xfce4-terminal >/dev/null 2>&1; then
    exec xfce4-terminal --title="Hudut Eggs ISO Tools" --command="bash -lc 'echo Hudut Penguins Eggs ISO Tools; echo; eggs --help; echo; read -p \"Kapatmak için Enter...\"'"
elif command -v x-terminal-emulator >/dev/null 2>&1; then
    exec x-terminal-emulator -e bash -lc 'echo Hudut Penguins Eggs ISO Tools; echo; eggs --help; echo; read -p "Kapatmak için Enter..."'
else
    eggs --help
fi
